# The following files and directories are not required in GitHub (e.g., dependencies, build outputs, local setup guides, and sensitive environment configs).
# Keeping them local prevents repo bloat and avoids exposing credentials.

# Dependencies
/node_modules
/.pnp
.pnp.js

# Testing
/coverage

# Next.js Build Outputs
/.next/
/out/

# Production Build
/build

# Debug Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment and Secret Files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env.*

# Local Documentation and Setup Guides
setup_guide.md
SETUP_GUIDE.md

# Operating System Metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and Editor Files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
